POSTGRES_USER=sandbox
POSTGRES_PASSWORD=sandbox_dev_password
POSTGRES_DB=postgis
POSTGRES_PORT=5439

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3_BUCKET=sandbox-data
S3_ENDPOINT=http://localhost:9000

# Bug reporting — creates GitHub issues from user reports
# Create a fine-grained token with Issues write permission:
# https://github.com/settings/tokens?type=beta
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPO=owner/repo

# Deployment — only needed when running with: docker compose --profile prod up
# DuckDNS: sign up at https://www.duckdns.org and create a subdomain
# Generate password hash: docker run --rm caddy caddy hash-password --plaintext 'your-password'
# SITE_ADDRESS=your-subdomain.duckdns.org
# DUCKDNS_TOKEN=your-token-here
# AUTH_USER=demo
# AUTH_PASSWORD_HASH=$$2a$$14$$...  (escape $ as $$ for Docker Compose)
