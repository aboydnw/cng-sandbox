# .env.example
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL (defaults work for local development)
POSTGRES_USER=sandbox
POSTGRES_PASSWORD=sandbox_dev_password
POSTGRES_DB=postgis
POSTGRES_PORT=5439

# Cloudflare R2 (S3-compatible object store)
# Create a bucket and API token at https://dash.cloudflare.com/ → R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-your_public_bucket_url.r2.dev

S3_BUCKET=sandbox-data

# Production only (not needed for local development)
# SITE_ADDRESS=cngsandbox.org
# AUTH_USER=demo
# AUTH_PASSWORD_HASH=$$2a$$14$$...

# GitHub (for bug report integration)
# GITHUB_TOKEN=github_pat_...
# GITHUB_REPO=owner/repo
