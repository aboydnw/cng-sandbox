POSTGRES_USER=sandbox
POSTGRES_PASSWORD=sandbox_dev_password
POSTGRES_DB=postgis
POSTGRES_PORT=5439

S3_BUCKET=sandbox-data

# Cloudflare R2 — create an API token at https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key-id
# R2_SECRET_ACCESS_KEY=your-secret-access-key
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Bug reporting — creates GitHub issues from user reports
# Create a fine-grained token with Issues write permission:
# https://github.com/settings/tokens?type=beta
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPO=owner/repo

# Deployment — only needed for production
# Cloudflare Tunnel: create at https://one.dash.cloudflare.com → Networks → Tunnels
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# Vercel URL (for CORS headers) — set to your *.vercel.app URL
# VERCEL_URL=https://your-app.vercel.app

# Public URLs — set these to your tunnel URL so the API returns
# browser-accessible URLs (instead of relative paths)
# PUBLIC_RASTER_TILER_URL=https://api.yourdomain.com/raster
# PUBLIC_VECTOR_TILER_URL=https://api.yourdomain.com/vector
# PUBLIC_STORAGE_URL=https://pub-<hash>.r2.dev
