{
  "name": "cng-sandbox",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "vite",
    "build": "yarn build:viewer && tsc && vite build",
    "build:viewer": "vite build --config vite.viewer.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "postinstall": "mkdir -p public && test -f node_modules/gif.js/dist/gif.worker.js && cp node_modules/gif.js/dist/gif.worker.js public/gif.worker.js || true"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@deck.gl/core": "^9.3.4",
    "@deck.gl/extensions": "^9.3.4",
    "@deck.gl/geo-layers": "^9.3.4",
    "@deck.gl/layers": "^9.3.4",
    "@deck.gl/mesh-layers": "^9.3.4",
    "@deck.gl/react": "^9.3.4",
    "@deck.gl/widgets": "^9.3.4",
    "@developmentseed/deck.gl-geotiff": "^0.7.0",
    "@developmentseed/deck.gl-raster": "^0.7.0",
    "@developmentseed/deck.gl-zarr": "0.7.0",
    "@duckdb/duckdb-wasm": "^1.29.0",
    "@emotion/react": "^11.0.0",
    "@geoarrow/deck.gl-layers": "^0.3.1",
    "@luma.gl/core": "^9.3.5",
    "@luma.gl/engine": "^9.3.5",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.101.1",
    "apache-arrow": "^21.1.0",
    "d3-format": "^3.1.0",
    "d3-scale": "^4.0.2",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "gif.js": "^0.2.0",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "lerc": "^4.0.4",
    "maplibre-gl": "^5.24.0",
    "mp4-muxer": "^5.2.2",
    "papaparse": "^5.5.4",
    "pmtiles": "^4.4.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.7",
    "react-map-gl": "^8.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "scrollama": "^3.2.0",
    "zarrita": "0.7.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-format": "^3.0.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.0",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "@luma.gl/core": "9.3.5",
    "@luma.gl/engine": "9.3.5"
  }
}
