:80 {
    handle /api/* {
        reverse_proxy ingestion:8000 {
            flush_interval -1
        }
    }

    handle /raster/* {
        uri strip_prefix /raster
        reverse_proxy raster-tiler:80
    }

    handle /vector/* {
        uri strip_prefix /vector
        reverse_proxy vector-tiler:80
    }
}
